    "flows": [
      {
        "id": "flow.cli_command_dispatch",
        "name": "CLI command dispatch routes argv to service operations",
        "touches": [
          "component.cli_app",
          "component.cli_init_command",
          "component.cli_graph_read_command",
          "component.cli_graph_context_command",
          "component.cli_proposal_commands",
          "component.knowledge_graph_service",
          "component.repo_context_detection"
        ]
      },
      {
        "id": "flow.repo_context_detection",
        "name": "Detect repo root, remote URL, repo name, and default branch from Git",
        "touches": [
          "component.repo_context_detection",
          "component.cli_app"
        ]
      },
      {
        "id": "flow.repo_initialization",
        "name": "Initialize repo memory with main and working scopes",
        "touches": [
          "component.cli_init_command",
          "component.repo_context_detection",
          "component.knowledge_graph_service",
          "component.sqlite_repository",
          "component.scope_model"
        ]
      },
      {
        "id": "flow.graph_read",
        "name": "Read current graph view for main plus working scopes",
        "touches": [
          "component.cli_graph_read_command",
          "component.knowledge_graph_service",
          "component.sqlite_repository",
          "component.active_graph_view"
        ]
      },
      {
        "id": "flow.graph_context",
        "name": "Build a graph context bundle for a natural-language query",
        "touches": [
          "component.cli_graph_context_command",
          "component.knowledge_graph_service",
          "component.sqlite_repository",
          "component.graph_context_retrieval",
          "component.active_graph_view"
        ]
      },
      {
        "id": "flow.proposal_validation",
        "name": "Normalize and validate proposal structure before apply",
        "touches": [
          "component.cli_proposal_commands",
          "component.knowledge_graph_service",
          "component.proposal_model",
          "component.proposal_normalization",
          "component.proposal_validation",
          "component.edge_rules"
        ]
      },
      {
        "id": "flow.proposal_apply",
        "name": "Apply valid proposal into the working scope as a memory commit",
        "touches": [
          "component.cli_proposal_commands",
          "component.knowledge_graph_service",
          "component.proposal_normalization",
          "component.proposal_validation",
          "component.sqlite_repository",
          "component.memory_commit_model",
          "component.scope_model"
        ]
      },
      {
        "id": "flow.compact_relationships_to_edges",
        "name": "Convert compact relationship fields into canonical graph edges",
        "touches": [
          "component.proposal_model",
          "component.proposal_normalization",
          "component.edge_rules",
          "component.graph_schema"
        ]
      },
      {
        "id": "flow.edge_validation",
        "name": "Validate graph edge endpoint existence and allowed direction",
        "touches": [
          "component.proposal_validation",
          "component.edge_rules",
          "component.graph_schema"
        ]
      },
      {
        "id": "flow.active_graph_view",
        "name": "Compose active graph records from current scopes and filter edge endpoints",
        "touches": [
          "component.sqlite_repository",
          "component.active_graph_view",
          "component.scope_model",
          "component.graph_schema"
        ]
      },
      {
        "id": "flow.sqlite_persistence",
        "name": "Persist graph objects, edges, memberships, scopes, and commits in SQLite",
        "touches": [
          "component.sqlite_database",
          "component.sqlite_schema",
          "component.sqlite_repository",
          "component.scope_model",
          "component.memory_commit_model"
        ]
      },
      {
        "id": "flow.bootstrap_eval_generation",
        "name": "Bootstrap eval obtains a proposal from a fixture or Codex agent",
        "touches": [
          "component.bootstrap_eval_runner",
          "component.agent_runner_codex",
          "component.engineering_memory_skill"
        ]
      },
      {
        "id": "flow.bootstrap_eval_judging",
        "name": "Bootstrap eval judges proposal coverage and quality with rubric-driven scoring",
        "touches": [
          "component.bootstrap_eval_runner",
          "component.bootstrap_eval_rubric",
          "component.agent_runner_metrics"
        ]
      },
      {
        "id": "flow.engineering_memory_bootstrap",
        "name": "Engineering memory skill guides shallow repo inspection and validated proposal creation",
        "touches": [
          "component.engineering_memory_skill",
          "component.cli_app",
          "component.cli_graph_read_command",
          "component.cli_proposal_commands"
        ]
      },
      {
        "id": "flow.local_database_isolation",
        "name": "ENGINEERING_CONTEXT_HOME isolates local SQLite database state",
        "touches": [
          "component.sqlite_database",
          "component.bootstrap_eval_runner",
          "component.search_eval_fixture"
        ]
      },
      {
        "id": "flow.search_eval_retrieval",
        "name": "Search eval seeds a deep graph fixture and scores task-sentence retrieval",
        "touches": [
          "component.search_eval_fixture",
          "component.cli_graph_context_command",
          "component.graph_context_retrieval",
          "component.active_graph_view"
        ]
      }
