    "claims": [
      {
        "id": "claim.cli_is_thin_service_wrapper",
        "kind": "fact",
        "text": "The CLI is a thin local wrapper that parses argv, detects repository context, reads proposal files, prints command output, and delegates graph behavior to KnowledgeGraphService.",
        "truth": "code_verified",
        "intent": "intended",
        "about": [
          "component.cli_app",
          "flow.cli_command_dispatch"
        ]
      },
      {
        "id": "claim.cli_constructs_service_once",
        "kind": "fact",
        "text": "The CLI constructs a local KnowledgeGraphService once at startup before routing commands.",
        "truth": "code_verified",
        "intent": "intended",
        "about": [
          "component.cli_app",
          "component.knowledge_graph_service"
        ]
      },
      {
        "id": "claim.init_prints_repo_scope_database",
